{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"mount_file_id":"121pT292FPiJLKhtdyw6bMvIfJmNJA7HC","authorship_tag":"ABX9TyN+/4PAcAiF0YhM9R8/YLjZ"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["# ==========================================================\n","# STEP 1: Install Dependencies & Import Libraries\n","# ==========================================================\n","!pip install timm\n","\n","import torch\n","import torch.nn as nn\n","import timm\n","from torchvision import transforms\n","from PIL import Image\n","import matplotlib.pyplot as plt\n","import numpy as np\n","import os\n","from IPython.display import display, Image as IPImage\n","\n","# ==========================================================\n","# STEP 2: Folder Setup and Select One Test Image\n","# ==========================================================\n","img_folder = \"/content/drive/MyDrive/road_separated/good_roads\"\n","output_folder = \"/content/drive/MyDrive/OUTPUT FOLDER/HR_Former\"\n","os.makedirs(output_folder, exist_ok=True)\n","\n","img_list = [f for f in os.listdir(img_folder) if f.lower().endswith(('.jpg', '.jpeg', '.png'))]\n","if not img_list:\n","    raise ValueError(f\"No images found in {img_folder}\")\n","\n","img_path = os.path.join(img_folder, img_list[0])\n","img_name = os.path.splitext(os.path.basename(img_path))[0]\n","\n","# ==========================================================\n","# STEP 3: Input Road Image\n","# ==========================================================\n","print(\"🔹 Step 3: Displaying Input Road Image\")\n","input_image = Image.open(img_path).convert(\"RGB\")\n","display(input_image)\n","input_image.save(os.path.join(output_folder, f\"{img_name}_input_road_image.png\"))\n","\n","# ==========================================================\n","# STEP 4: Preprocessing (Resize + Tensor Conversion)\n","# ==========================================================\n","print(\"🔹 Step 4: Preprocessing Image\")\n","\n","transform = transforms.Compose([\n","    transforms.Resize((224, 224)),\n","    transforms.ToTensor(),\n","])\n","\n","input_tensor = transform(input_image).unsqueeze(0)\n","\n","# Convert tensor back to image for verification\n","preproc_img = transforms.ToPILImage()(input_tensor.squeeze(0).cpu())\n","preproc_img.save(os.path.join(output_folder, f\"{img_name}_preprocessed.png\"))\n","display(preproc_img)\n","\n","# ==========================================================\n","# STEP 5: CNN Backbone (ResNet18 Feature Extraction)\n","# ==========================================================\n","print(\"🔹 Step 5: Extracting Features from CNN Backbone\")\n","\n","class FeatureExtractor(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.backbone = timm.create_model(\"resnet18\", pretrained=True, features_only=True)\n","    def forward(self, x):\n","        return self.backbone(x)\n","\n","device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n","model = FeatureExtractor().to(device)\n","model.eval()\n","\n","# ==========================================================\n","# STEP 6: Forward Pass & Feature Map Visualization\n","# ==========================================================\n","print(\"🔹 Step 6: Visualizing Feature Maps\")\n","\n","input_tensor = input_tensor.to(device)\n","with torch.no_grad():\n","    features = model(input_tensor)\n","\n","for i, f in enumerate(features):\n","    fmap = f[0]  # first in batch\n","    fmap_np = np.sum(fmap.cpu().numpy(), axis=0)\n","    fmap_np = (fmap_np - np.min(fmap_np)) / (np.ptp(fmap_np) + 1e-6)\n","    map_path = os.path.join(output_folder, f\"{img_name}_feature_map_{i}.png\")\n","\n","    plt.figure(figsize=(6, 6), dpi=100)\n","    plt.imshow(fmap_np, cmap=\"viridis\")\n","    plt.axis(\"off\")\n","    plt.title(f\"Feature Map {i}\", fontsize=12)\n","    plt.tight_layout()\n","    plt.savefig(map_path, bbox_inches='tight', pad_inches=0.05)\n","    plt.show()\n","\n","    print(f\"✅ Saved Feature Map {i}: {map_path}\")\n","    display(IPImage(map_path))\n","\n","# ==========================================================\n","# STEP 7: Grad-CAM Heatmap (Fixed for NumPy 2.0)\n","# ==========================================================\n","print(\"🔹 Step 7: Generating Grad-CAM Heatmap\")\n","\n","def grad_cam_simple(feature_map):\n","    fmap = feature_map.detach().cpu().numpy()[0]\n","    heatmap = np.mean(fmap, axis=0)\n","    heatmap = np.maximum(heatmap, 0)\n","    heatmap = (heatmap - np.min(heatmap)) / (np.ptp(heatmap) + 1e-6)\n","    return heatmap\n","\n","heatmap = grad_cam_simple(features[-1])\n","heatmap_path = os.path.join(output_folder, f\"{img_name}_gradcam_heatmap.png\")\n","\n","plt.figure(figsize=(6, 6), dpi=100)\n","plt.imshow(heatmap, cmap=\"jet\")\n","plt.axis(\"off\")\n","plt.title(\"Grad-CAM Heatmap\", fontsize=12)\n","plt.tight_layout()\n","plt.savefig(heatmap_path, bbox_inches='tight', pad_inches=0.05)\n","plt.show()\n","\n","display(IPImage(heatmap_path))\n","\n","# ==========================================================\n","# STEP 8: Combined Visualization Grid\n","# ==========================================================\n","print(\"🔹 Step 8: Creating Final Visualization Grid\")\n","\n","fig, axs = plt.subplots(2, 4, figsize=(14, 7), dpi=100)\n","axs = axs.flatten()\n","\n","num_features = min(6, len(features))\n","for i in range(num_features):\n","    fmap = features[i][0]\n","    fmap_np = np.sum(fmap.cpu().numpy(), axis=0)\n","    fmap_np = (fmap_np - np.min(fmap_np)) / (np.ptp(fmap_np) + 1e-6)\n","    axs[i].imshow(fmap_np, cmap=\"viridis\")\n","    axs[i].set_title(f\"Feature {i}\", fontsize=10)\n","    axs[i].axis(\"off\")\n","\n","axs[6].imshow(input_image)\n","axs[6].set_title(\"Original\", fontsize=10)\n","axs[6].axis(\"off\")\n","\n","axs[7].imshow(preproc_img)\n","axs[7].imshow(heatmap, cmap=\"jet\", alpha=0.5)\n","axs[7].set_title(\"Grad-CAM Overlay\", fontsize=10)\n","axs[7].axis(\"off\")\n","\n","plt.tight_layout()\n","viz_path = os.path.join(output_folder, f\"{img_name}_full_visualization.png\")\n","plt.savefig(viz_path, bbox_inches='tight', pad_inches=0.1)\n","plt.show()\n","\n","display(IPImage(viz_path))\n","\n","print(f\"\\n✅ All smaller, corrected outputs saved in folder:\\n{output_folder}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000,"output_embedded_package_id":"1MbTV_CwxAdbLs_ZHB-5wiZEMHz7hC39-"},"id":"LcOThrvvn4Q9","executionInfo":{"status":"ok","timestamp":1760796968952,"user_tz":-330,"elapsed":10490,"user":{"displayName":"Road Paper","userId":"18108632633372812899"}},"outputId":"ce1f5da8-a291-4a57-dac1-eb87ab5aac06"},"execution_count":33,"outputs":[{"output_type":"display_data","data":{"text/plain":"Output hidden; open in https://colab.research.google.com to view."},"metadata":{}}]}]}