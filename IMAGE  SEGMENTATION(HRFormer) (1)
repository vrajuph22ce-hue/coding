{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyM/UF8w9uaxzjsjml9wmjsS"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["# =============================\n","# STEP 1: Imports & Setup\n","# =============================\n","from google.colab import drive\n","import os\n","import cv2\n","import numpy as np\n","import matplotlib.pyplot as plt\n","\n","# Mount Google Drive\n","drive.mount('/content/drive')\n","\n","# Dataset & output paths\n","datapath = '/content/drive/MyDrive/road_separated'  # parent with good_roads & bad_roads\n","outputdir = '/content/drive/MyDrive/OUTPUT FOLDER/HR_Former'\n","os.makedirs(outputdir, exist_ok=True)\n","print(\"Output directory ready:\", outputdir)\n","\n","# Helper to display\n","def show(img, title=\"Image\", cmap='gray'):\n","    plt.figure(figsize=(6,6))\n","    if len(img.shape) == 2:\n","        plt.imshow(img, cmap=cmap)\n","    else:\n","        plt.imshow(cv2.cvtColor(img, cv2.COLOR_BGR2RGB))\n","    plt.title(title)\n","    plt.axis(\"off\")\n","    plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"YuaS2GY4Rtfk","executionInfo":{"status":"ok","timestamp":1759385380180,"user_tz":-330,"elapsed":19732,"user":{"displayName":"Road Paper","userId":"18108632633372812899"}},"outputId":"6e962c1f-0d10-4a4b-e599-fc9663535bfa"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","Output directory ready: /content/drive/MyDrive/OUTPUT FOLDER/HR_Former\n"]}]},{"cell_type":"code","source":["# Load an example image (first one from good_roads)\n","img_path = os.path.join(datapath, \"good_roads\", os.listdir(os.path.join(datapath, \"good_roads\"))[0])\n","img = cv2.imread(img_path)\n","\n","show(img, \"STEP 1: Input Image\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":408},"id":"lDz9qn5-R35o","executionInfo":{"status":"ok","timestamp":1759045465343,"user_tz":-330,"elapsed":1657,"user":{"displayName":"Road Paper","userId":"18108632633372812899"}},"outputId":"4655c0e2-a863-48d2-8360-e45fcff52c39"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n","\n","clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))\n","enhanced = clahe.apply(gray)\n","\n","enhanced = cv2.bilateralFilter(enhanced, 9, 75, 75)\n","\n","show(enhanced, \"STEP 2: Local Enhancement (CLAHE + Filter)\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":408},"id":"0PII8SlXR7pZ","executionInfo":{"status":"ok","timestamp":1759045491800,"user_tz":-330,"elapsed":2329,"user":{"displayName":"Road Paper","userId":"18108632633372812899"}},"outputId":"5f6d67de-9af8-4fbd-de61-ff75c2f3eec6"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["down1 = cv2.pyrDown(enhanced)\n","down2 = cv2.pyrDown(down1)\n","\n","up1 = cv2.pyrUp(down1, dstsize=enhanced.shape[::-1])\n","up2 = cv2.pyrUp(cv2.pyrUp(down2), dstsize=enhanced.shape[::-1])\n","\n","fusion = cv2.addWeighted(enhanced, 0.6, up1, 0.2, 0)\n","fusion = cv2.addWeighted(fusion, 0.8, up2, 0.2, 0)\n","\n","show(fusion, \"STEP 3: Multi-Scale Context (Fusion)\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":408},"id":"w2pICgPwSBqM","executionInfo":{"status":"ok","timestamp":1759045505136,"user_tz":-330,"elapsed":1265,"user":{"displayName":"Road Paper","userId":"18108632633372812899"}},"outputId":"76653a37-9552-40ae-8596-390bd433dfb0"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["sobelx = cv2.Sobel(fusion, cv2.CV_64F, 1, 0, ksize=3)\n","sobely = cv2.Sobel(fusion, cv2.CV_64F, 0, 1, ksize=3)\n","sobel = cv2.magnitude(sobelx, sobely)\n","sobel = np.uint8(sobel / sobel.max() * 255)\n","\n","_, mask = cv2.threshold(sobel, 50, 255, cv2.THRESH_BINARY)\n","\n","show(mask, \"STEP 4: Attention Mask (Sobel + Thresholding)\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":408},"id":"hFP94p-DSFSB","executionInfo":{"status":"ok","timestamp":1759045516320,"user_tz":-330,"elapsed":2037,"user":{"displayName":"Road Paper","userId":"18108632633372812899"}},"outputId":"45528a8e-b22e-400c-fcb0-a7cbf3321753"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["kernel = np.ones((5,5), np.uint8)\n","\n","closed = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, kernel)\n","refined = cv2.dilate(closed, kernel, iterations=1)\n","\n","show(refined, \"STEP 5: Refinement (Closing + Dilation)\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":408},"id":"VwNWR35DSHrs","executionInfo":{"status":"ok","timestamp":1759045529868,"user_tz":-330,"elapsed":2113,"user":{"displayName":"Road Paper","userId":"18108632633372812899"}},"outputId":"e7b77e0f-6d6d-4111-bdfd-d9e58d5f9e28"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["final_mask = refined\n","show(final_mask, \"STEP 6: Final Mask Output\")\n","\n","cv2.imwrite(os.path.join(outputdir, \"final_mask.png\"), final_mask)\n","print(\"Final mask saved:\", os.path.join(outputdir, \"final_mask.png\"))\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":425},"id":"lXce0OedSKus","executionInfo":{"status":"ok","timestamp":1759045544830,"user_tz":-330,"elapsed":2131,"user":{"displayName"