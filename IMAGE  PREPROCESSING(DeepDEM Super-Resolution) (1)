model.predict(np.expand_dims(lr,0))[-1][0] for lr in lr_bad]\n","\n","# --------------------------\n","# Visualization Function\n","# --------------------------\n","def show_results(lr, sr, hr, title):\n","    plt.figure(figsize=(12, 4))\n","    n = len(lr)\n","    for i in range(n):\n","        # Low Resolution\n","        plt.subplot(3, n, i + 1)\n","        plt.imshow(lr[i])\n","        plt.axis('off')\n","        plt.title(\"Low Res\")\n","\n","        # Super-Resolution\n","        plt.subplot(3, n, n + i + 1)\n","        plt.imshow(np.clip(sr[i],0,1))\n","        plt.axis('off')\n","        plt.title(\"Super-Res\")\n","\n","        # High Resolution Ground Truth\n","        plt.subplot(3, n, 2 * n + i + 1)\n","        plt.imshow(hr[i])\n","        plt.axis('off')\n","        plt.title(\"High Res (GT)\")\n","\n","    plt.suptitle(title)\n","    plt.tight_layout()\n","    plt.show()\n","\n","# --------------------------\n","# Display Results\n","# --------------------------\n","show_results(lr_good, preds_good, hr_good, \"DeepDEM Super-Resolution - Good Roads\")\n","show_results(lr_bad, preds_bad, hr_bad, \"DeepDEM Super-Resolution - Bad Roads\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":983},"id":"u1zGIB2RJ4pw","executionInfo":{"status":"ok","timestamp":1759043429081,"user_tz":-330,"elapsed":6593,"user":{"displayName":"Road Paper","userId":"18108632633372812899"}},"outputId":"0ffd5bc9-5d35-40c5-b460-a3a05b27e1c2"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[1m1/1\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 54ms/step\n","\u001b[1m1/1\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 51ms/step\n","\u001b[1m1/1\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 48ms/step\n","\u001b[1m1/1\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001