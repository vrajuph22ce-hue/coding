er = \"/content/drive/MyDrive/road_separated/good_roads\"\n","output_folder = \"/content/drive/MyDrive/OUTPUT FOLDER/CLASSIFICATION\"\n","os.makedirs(output_folder, exist_ok=True)\n","\n","import torch\n","import torch.nn as nn\n","from torchvision import models, transforms\n","from PIL import Image\n","import numpy as np\n","import matplotlib.pyplot as plt\n","\n","# ==============================\n","# STEP 2: Define SE Block and Modified ResNet18\n","# ==============================\n","class SEBlock(nn.Module):\n","    def __init__(self, channel, reduction=16):\n","        super(SEBlock, self).__init__()\n","        self.avg_pool = nn.AdaptiveAvgPool2d(1)\n","        self.fc = nn.Sequential(\n","            nn.Linear(channel, channel // reduction, bias=False),\n","            nn.ReLU(inplace=True),\n","            nn.Linear(channel // reduction, channel, bias=False),\n","            nn.Sigmoid()\n","        )\n","    def forward(self, x):\n","        b, c, _, _ = x.size()\n","        y = self.avg_pool(x).view(b, c)\n","        y = self.fc(y).view(b, c, 1, 1)\n","        return x * y.expand_as(x)\n","\n","class StepSE_ResNet18(nn.Module):\n","    def __init__(self, num_classes=2):\n","        super().__init__()\n","        backbone = models.resnet18(pretrained=True)\n","        self.stem = nn.Sequential(\n","            backbone.conv1, backbone.bn1, backbone.relu, backbone.maxpool\n","        )\n","        self.layer1 = nn.Sequential(backbone.layer1, SEBlock(64))\n","        self.layer2 = nn.Sequential(backbone.layer2, SEBlock(128))\n","        self.layer3 = nn.Sequential(backbone.layer3, SEBlock(256))\n","        self.layer4 = nn.Sequential(backbone.layer4, SEBlock(512))\n","        self.avgpool = backbone.avgpool\n","        self.fc = nn.Linear(512, num_classes)\n","        self.sm = nn.Softmax(dim=1)\n","\n","    def forward(self, x):\n","        features = {}\n","        x1 = self.stem(x)\n","        features['stem'] = x1\n","        x2 = self.layer1(x1)\n","        features['layer1'] = x2\n","        x3 = self.layer2(x2)\n","        features['layer2'] = x3\n","        x4 = self.layer3(x3)\n","        features['layer3'] = x4\n","        x5 = self.layer4(x4)\n","        features['layer4'] = x5\n","        pooled = self.avgpool(x5)\n","        features['avgpool'] = pooled\n","        out = pooled.view(pooled.size(0), -1)\n","        fc_out = self.fc(out)\n","        features['fc'] = fc_out\n","        softmaxed = self.sm(fc_out)\n","        features['softmax'] = softmaxed\n","        return features\n","\n","# ==============================\n","# STEP 3: Load and Preprocess Image\n","# ==============================\n","img_name = sorted([f for f in os.listdir(input_folder) if f.lower().endswith(('.jpg','.png'))])[0]\n","img_path = os.path.join(input_folder, img_name)\n","\n","transform = transforms.Compose([\n","    transforms.Resize((224,224)),\n","    transforms.ToTensor(),\n","    transforms.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225]),\n","])\n","\n","orig = Image.open(img_path).convert('RGB')\n","prep = transform(orig)\n","input_tensor = prep.unsqueeze(0)\n","\n","# Show preprocessing\n","fig, axes = plt.subplots(1,3, figsize=(12,4))\n","axes[0].imshow(orig)\n","axes[0].set_title(\"Original\")\n","axes[0].axis(\"off\")\n","axes[1].imshow(np.array(orig.resize((224,224))))\n","axes[1].set_title(\"Resized\")\n","axes[1].axis(\"off\")\n","axes[2].imshow(np.transpose(prep.numpy(), (1,2,0)).clip(0,1))\n","axes[2].set_title(\"Normalized Tensor\")\n","axes[2].axis(\"off\")\n","plt.suptitle(\"Preprocessing (Resize → Normalize → Tensor)\")\n","plt.tight_layout()\n","plt.show()\n","\n","# ==============================\n","# STEP 4: Forward Pass and Visualization\n","# ==============================\n","import torchvision.utils as vutils\n","\n","device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n","model = StepSE_ResNet18(num_classes=2).to(device)\n","model.eval()\n","with torch.no_grad():\n","    feat = model(input_tensor.to(device))\n","\n","def show_and_save_stage(stage_tensor, name, num_ch=8):\n","    arr = stage_tensor[0]\n","    ch = min(num_ch, arr.shape[0])\n","    grid = vutils.make_grid(arr[:ch].unsqueeze(1), nrow=ch, normalize=True, scale_each=True, pad_value=1)\n","    grid_img = np.transpose(grid.cpu().numpy(), (1, 2, 0))\n","    plt.figure(figsize=(ch*2, 2))\n","    plt.imshow(grid_img, cmap='viridis')\n","    plt.title(name)\n","    plt.axis(\"off\")\n","    plt.show()\n","    plt.savefig(os.path.join(output_folder, f\"{name}.png\"))\n","    plt.close()\n","\n","show_and_save_stage(feat['stem'].cpu(), \"02_stem\", 8)\n","show_and_save_stage(feat['layer1'].cpu(), \"03_layer1_se1\", 8)\n","show_and_save_stage(feat['layer2'].cpu(), \"04_layer2_se2\", 8)\n","show_and_save_stage(feat['layer3'].cpu(), \"05_layer3_se3\", 8)\n","show_and_save_stage(feat['layer4'].cpu(), \"06_layer4_se4\", 8)\n","\n","# Global AvgPool visualization\n","vec = feat['avgpool'].cpu().view(-1).numpy()\n","plt.figure(figsize=(10,2))\n","plt.bar(np.arange(len(vec)), vec)\n","plt.title(\"07_Global Average Pooling\")\n","plt.show()\n","plt.savefig(os.path.join(output_folder, \"07_global_avgpool.png\"))\n","plt.close()\n","\n","# Fully Connected output\n","fc = feat['fc'].cpu().numpy().flatten()\n","plt.figure(figsize=(5,2))\n","plt.bar([0,1], fc)\n","plt.xticks([0,1], ['Good','Bad'])\n","plt.title(\"08_FC Layer Output\")\n","plt.show()\n","plt.savefig(os.path.join(output_folder, \"08_fc.png\"))\n","plt.close()\n","\n","# Softmax probabilities\n","sf = feat['softmax'].cpu().numpy().flatten()\n","plt.figure(figsize=(5,2))\n","plt.bar([0,1], sf)\n","plt.xticks([0,1], ['Good','Bad'])\n","plt.title(\"09_Softmax Probabilities\")\n","plt.show()\n","plt.savefig(os.path.join(output_folder, \"09_softmax.png\"))\n","plt.close()\n","\n","final = \"Good Road\" if sf[0] > sf[1] else \"Bad Road\"\n","print(f\"✅ Predicted: {final}\")\n","print(f\"Softmax Probabilities: {sf}\")\n","\n","with open(os.path.join(output_folder, \"10_prediction.txt\"), \"w\") as f:\n","    f.write(f\"Predicted: {final}\\nSoftmax: {sf}\\n\")\n","\n","# ==============================\n","# STEP 5: Grad-CAM Generation\n","# ==============================\n","def generate_gradcam(model, input_tensor, target_class=None):\n","    grad_model = StepSE_ResNet18(num_classes=2).to(device)\n","    grad_model.load_state_dict(model.state_dict())\n","    grad_model.eval()\n","\n","    input_tensor = input_tensor.to(device)\n","    x = grad_model.stem(input_tensor)\n","    x = grad_model.layer1(x)\n","    x = grad_model.layer2(x)\n","    x = grad_model.layer3(x)\n","    x = grad_model.layer4(x)\n","    features = x\n","    pooled = grad_model.avgpool(x)\n","    pooled = pooled.view(pooled.size(0), -1)\n","    output = grad_model.fc(pooled)\n","    if target_class is None:\n","        target_class = output.argmax(dim=1).item()\n","    score = output[:, target_class]\n","    grad_model.zero_grad()\n","    score.backward(retain_graph=True)\n","    gradients = grad_model.layer4[1].fc[0].weight.grad\n","    weights = gradients.mean(dim=[0,1], keepdim=True) # Corrected dimensions\n","    gradcam = torch.sum(weights * features, dim=1).squeeze()\n","    gradcam = torch.relu(gradcam)\n","    gradcam = gradcam.cpu().detach().numpy()\n","    gradcam = (gradcam - gradcam.min()) / (gradcam.max() - gradcam.min())\n","    gradcam = np.uint8(255 * gradcam)\n","    gradcam = np.stack([gradcam]*3, axis=-1)\n","    gradcam_img = cv2.resize(gradcam, (224,224))\n","    return gradcam_img\n","\n","import cv2\n","gradcam_img = generate_gradcam(model, input_tensor)\n","gradcam_heatmap = cv2.applyColorMap(gradcam_img, cv2.COLORMAP_JET)\n","orig_resized_cv = cv2.resize(np.array(orig), (224,224))\n","overlay = cv2.addWeighted(orig_resized_cv, 0.6, gradcam_heatmap, 0.4, 0)\n","cv2.imwrite(os.path.join(output_folder, \"gradcam_result.png\"), cv2.cvtColor(overlay, cv2.COLOR_RGB2BGR))\n"]},{"cell_type":"code","source":["import os\n","from PIL import Image\n","import matplotlib.pyplot as plt\n","import random\n","\n","# === Path to your images folder ===\n","input_folder = \"/content/drive/MyDrive/road_separated/good_roads\"\n","\n","# === Get image list and shuffle/select 9 ===\n","img_files = [f for f in os.listdir(input_folder) if f.lower().endswith(('.jpg','.png'))]\n","random.shuffle(img_files)\n","img_files = img_files[:9]\n","\n","# === Create a 3x3 grid ===\n","fig, axes = plt.subplots(3, 3, figsize=(10,10))\n","axes = axes.flatten()\n","\n","for idx, ax in enumerate(axes):\n","    img_path = os.path.join(input_folder, img_files[idx])\n","    img = Image.open(img_path).convert('RGB')\n","    ax.imshow(img)\n","    ax.axis('off')\n","\n","plt.tight_layout()\n","plt.savefig(\"/content/drive/MyDrive/road_separated/image_grid.png\")\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":891},"id":"Q4UrfnakaR-4","executionInfo":{"status":"ok","timestamp":1760793489252,"user_tz":-330,"elapsed":24730,"user":{"displayName":"Road Paper","userId":"18108632633372812899"}},"outputId":"24ae731b-3dcc-4a44-97a4-80ee2f58890d"},"execution_count":25,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x1000 with 9 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# ==============================\n","# STEP 6: ROC Curve and Confusion Matrix\n","# ==============================\n","from sklearn.metrics import roc_curve, auc, confusion_matrix, ConfusionMatrixDisplay\n","\n","# --- Collect predictions and true labels ---\n","# Assuming folder structure: good_roads = label 0, bad_roads = label 1\n","all_imgs = []\n","all_labels = []\n","\n","good_folder = \"/content/drive/MyDrive/road_separated/good_roads\"\n","bad_folder = \"/content/drive/MyDrive/road_separated/bad_roads\"\n","\n","for f in sorted(os.listdir(good_folder)):\n","    if f.lower().endswith(('.jpg','.png')):\n","        all_imgs.append(os.path.join(good_folder, f))\n","        all_labels.append(0)  # Good road = 0\n","\n","for f in sorted(os.listdir(bad_folder)):\n","    if f.lower().endswith(('.jpg','.png')):\n","        all_imgs.append(os.path.join(bad_folder, f))\n","        all_labels.append(1)  # Bad road = 1\n","\n","# --- Get model predictions ---\n","model.eval()\n","probs = []\n","\n","with torch.no_grad():\n","    for img_path in all_imgs:\n","        img = Image.open(img_path).convert('RGB')\n","        input_tensor = transform(img).unsqueeze(0).to(device)\n","        feat = model(input_tensor)\n","        probs.append(feat['softmax'].cpu().numpy().flatten())\n","\n","probs = np.array(probs)\n","preds = np.argmax(probs, axis=1)\n","true_labels = np.array(all_labels)\n","\n","# --- ROC Curve ---\n","fpr, tpr, thresholds = roc_curve(true_labels, probs[:,1])  # Use class 1 probability\n","roc_auc = auc(fpr, tpr)\n","\n","plt.figure(figsize=(6,6))\n","plt.plot(fpr, tpr, color='blue', lw=2, label=f'ROC curve (AUC = {roc_auc:.2f})')\n","plt.plot([0,1],[0,1], color='gray', linestyle='--')\n","plt.xlim([0.0,1.0])\n","plt.ylim([0.0,1.05])\n","plt.xlabel('False Positive Rate')\n","plt.ylabel('True Positive Rate')\n","plt.title('ROC Curve')\n","plt.legend(loc=\"lower right\")\n","plt.grid(True)\n","plt.savefig(os.path.join(output_folder, \"12_roc_curve.png\"))\n","plt.show()\n","\n","# --- Confusion Matrix ---\n","cm = confusion_matrix(true_labels, preds)\n","disp = ConfusionMatrixDisplay(cm, display_labels=['Good','Bad'])\n","disp.plot(cmap=plt.cm.Blues)\n","plt.title(\"Confusion Matrix\")\n","plt.savefig(os.path.join(output_folder, \"13_confusion_matrix.png\"))\n","plt.show()\n","\n","print(\"✅ ROC curve and Confusion Matrix saved.\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"YwWBO3mY5fMp","executionInfo":{"status":"ok","timestamp":1760791343744,"user_tz":-330,"elapsed":456963,"user":{"displayName":"Road Paper","userId":"18108632633372812899"}},"outputId":"6318cd3e-bdc8-47c5-